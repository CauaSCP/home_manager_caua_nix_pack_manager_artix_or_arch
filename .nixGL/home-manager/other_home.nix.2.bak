{ pkgs }:
let
  nixgl = import <nixgl> {};
  nixGLWrapper = nixgl.auto.nixGLDefault;

  wrapWithNixGL = pkg: pkgs.runCommand "${pkg.name}-nixgl-wrapper" {} ''
    mkdir -p $out

    # 1. Linka as pastas principais (evitando criar links rígidos nas profundezas do share)
    for dir in ${pkg}/*; do
      base=$(basename "$dir")
      if [ "$base" != "bin" ] && [ "$base" != "share" ]; then
        ln -s "$dir" "$out/$base"
      fi
    done

    # 2. Trata a pasta 'share' de forma isolada se ela existir
    if [ -d "${pkg}/share" ]; then
      mkdir -p $out/share
      for sdir in ${pkg}/share/*; do
        sbase=$(basename "$sdir")
        # Linka tudo dentro de share, EXCETO a pasta de aplicativos de interface (.desktop)
        if [ "$sbase" != "applications" ]; then
          ln -s "$sdir" "$out/share/$sbase"
        fi
      done
    fi

    # 3. Cria a pasta bin limpa e envelopa os binários para o Terminal
    mkdir -p $out/bin
    for bin in ${pkg}/bin/*; do
      wrapped_bin=$out/bin/$(basename $bin)
      bin_name=$(basename $bin)

      echo "BIN_NAME IS $bin_name"

      # Apenas a execução padrão é mais segura. O Kitty já busca o config na sua home por padrão.
      if [ "$bin_name" = "kitty" ]; then
        echo -e "#!/usr/bin/env bash\nexport HOME=/home/caua\nexec ${pkgs.lib.getExe nixGLWrapper} ''$bin --config /home/caua/.config/kitty/kitty.conf \"\$@\"" > $wrapped_bin
        echo "wrapped bin for kitty $wrapped_bin"
      else
        echo -e "#!/usr/bin/env bash\nexec ${pkgs.lib.getExe nixGLWrapper} ''$bin \"\$@\"" > $wrapped_bin
      fi

      chmod +x $wrapped_bin
    done

    # 4. Cria e corrige os atalhos .desktop na pasta isolada
    if [ -d "${pkg}/share/applications" ]; then
      mkdir -p $out/share/applications
      for desktop in ${pkg}/share/applications/*.desktop; do
        wrapped_desktop=$out/share/applications/$(basename $desktop)
        # Força o .desktop a chamar o seu wrapper do binário
        sed "s|Exec=|Exec=${pkgs.lib.getExe nixGLWrapper} |g" "$desktop" > "$wrapped_desktop"
      done
    fi
  '';

  # Carrega as listas de strings geradas pelo script
  guiNames = import ./gui-packages.nix;
  cliNames = import ./cli-packages.nix;

  # Converte as strings de texto em pacotes reais do Nixpkgs
  guiPackages = map (name: pkgs.${name}) guiNames;
  cliPackages = map (name: pkgs.${name}) cliNames;

in {
  # Instala tudo junto, separando o que vai rodar com nixGL
  home.packages = cliPackages ++ (map wrapWithNixGL guiPackages);
}
